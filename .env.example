# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-aqui

# ─── Magazord API ──────────────────────────────────────────────────────────────
# A API Magazord usa autenticação BasicAuth (usuário + senha da integração).
# No painel Magazord: Configurações → Integrações → Usuário de API
#
# Base URL: https://{nome-da-loja}.magazord.com.br  (sem /api no final)
VITE_MAGAZORD_BASE_URL=https://casalinda.magazord.com.br
VITE_MAGAZORD_USER=seu-usuario-api-aqui
VITE_MAGAZORD_PASS=sua-senha-api-aqui
