# ═══════════════════════════════════════════════════════════════════
#  ERP Casa Linda — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════════
#
#  COMO USAR:
#  1. Copie este arquivo para .env   →   cp .env.example .env
#  2. Preencha os valores abaixo
#  3. Reinicie o servidor:           →   npm run dev
#
#  VERCEL (produção):
#  Adicione todas as variáveis no painel:
#  vercel.com → Seu Projeto → Settings → Environment Variables
#  As variáveis sem prefixo VITE_ são usadas apenas pelas
#  Serverless Functions (nunca expostas ao browser).
# ═══════════════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────────
# Painel: app.supabase.com → Seu Projeto → Settings → API
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# URL pública do app — usada no redirect de recuperação de senha.
# Em desenvolvimento pode ficar vazio (usa window.location.origin automaticamente).
# Em produção (Vercel), adicione a URL completa: https://seu-app.vercel.app
VITE_APP_URL=https://seu-app.vercel.app


# ─── Magazord — LOCAL DEV (Vite proxy) ────────────────────────────
# Usado pelo vite.config.ts para injetar BasicAuth no proxy de dev.
# Em produção (Vercel), use as variáveis abaixo SEM prefixo VITE_.
VITE_MAGAZORD_BASE_URL=https://casalinda.magazord.com.br
VITE_MAGAZORD_USER=seu-usuario-api
VITE_MAGAZORD_PASS=sua-senha-api

# ─── Magazord — PRODUÇÃO (Vercel Serverless Function) ─────────────
# Estas variáveis ficam 100% server-side (sem prefixo VITE_).
# Adicione-as no painel da Vercel EM ADIÇÃO às VITE_ acima.
MAGAZORD_BASE_URL=https://casalinda.magazord.com.br
MAGAZORD_USER=seu-usuario-api
MAGAZORD_PASS=sua-senha-api
